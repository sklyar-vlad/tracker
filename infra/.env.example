ENV="production" # | development
 
 # backend
ADDR=":8080"
READ_TIMEOUT=10
WRITE_TIMEOUT=10
IDLE_TIMEOUT=60

# jwt
API_SECRET=secret-key

# database
DATABASE_URL=postgres://admin:admin@db:5432/self-dev

# goose environment
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://admin:admin@localhost:5432/self-dev
GOOSE_MIGRATION_DIR=./backend/migrations